.git
.gitignore
.env
.env.*
.claude/
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
dist/
*.egg-info/
tests/
*.md
# README.md is referenced by pyproject (readme = "README.md"); the hatchling
# build reads it for package metadata, so it must stay in the build context.
!README.md
