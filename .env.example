# Graph Store — select the backend: fuseki (default) | neo4j
GRAPH_STORE=fuseki

# Fuseki backend (GRAPH_STORE=fuseki)
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=ontorag
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin

# Neo4j + neosemantics backend (GRAPH_STORE=neo4j)
# Requires the [neo4j] extra:  uv pip install -e '.[neo4j]'
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontorag123
NEO4J_DATABASE=neo4j

# LLM Provider
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# Text embeddings (Neo4j `ontorag embed --mode textual|both`, GRAPH_STORE=neo4j)
EMBEDDING_PROVIDER=openai          # openai | ollama
# EMBEDDING_MODEL=text-embedding-3-small   # openai default; ollama: nomic-embed-text
# EMBEDDING_DIMENSION=1536                 # openai-3 default; ollama nomic: 768

# API Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
