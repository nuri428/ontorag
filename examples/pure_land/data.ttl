# ═════════════════════════════════════════════════════════════════════════════
# 48 VOWS OF AMITĀBHA (法藏比丘四十八願 from T0360)
# All 48 instances asserted so that count-based queries are answerable.
# Detailed description provided for the most celebrated vows; others carry
# vowNumber + canonical name only.
# ═════════════════════════════════════════════════════════════════════════════

pl:Vow_01 a pl:Vow ; pl:vowNumber 1  ;
    rdfs:label "No three evil destinies in the realm"@en , "國中無三惡道願"@zh-Hant , "국토무삼악도원"@ko ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "If, when I attain buddhahood, there should be in my realm any hell, animal realm, or hungry-ghost realm, may I not attain enlightenment."@en .

pl:Vow_02 a pl:Vow ; pl:vowNumber 2  ;
    rdfs:label "No falling back into evil destinies"@en , "不更惡趣願"@zh-Hant , "불갱악취원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_03 a pl:Vow ; pl:vowNumber 3  ;
    rdfs:label "All beings golden-coloured"@en , "悉皆金色願"@zh-Hant , "실개금색원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_04 a pl:Vow ; pl:vowNumber 4  ;
    rdfs:label "Bodies free of distinction"@en , "無有好醜願"@zh-Hant , "무유호추원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_05 a pl:Vow ; pl:vowNumber 5  ;
    rdfs:label "Knowledge of past lives"@en , "宿命通願"@zh-Hant , "숙명통원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_06 a pl:Vow ; pl:vowNumber 6  ;
    rdfs:label "Divine eye"@en , "天眼通願"@zh-Hant , "천안통원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_07 a pl:Vow ; pl:vowNumber 7  ;
    rdfs:label "Divine ear"@en , "天耳通願"@zh-Hant , "천이통원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_08 a pl:Vow ; pl:vowNumber 8  ;
    rdfs:label "Knowledge of others' minds"@en , "他心通願"@zh-Hant , "타심통원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_09 a pl:Vow ; pl:vowNumber 9  ;
    rdfs:label "Divine feet (instant travel)"@en , "神足通願"@zh-Hant , "신족통원"@ko ; pl:appearsIn pl:T0360 .
pl:Vow_10 a pl:Vow ; pl:vowNumber 10 ;
    rdfs:label "No notion of self"@en , "不貪計身願"@zh-Hant , "불탐계신원"@ko ; pl:appearsIn pl:T0360 .

pl:Vow_11 a pl:Vow ; pl:vowNumber 11 ;
    rdfs:label "Certain attainment of nirvāṇa"@en , "必至滅度願"@zh-Hant , "필지멸도원"@ko ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "Beings born in Sukhāvatī will inevitably attain final nirvāṇa."@en .

pl:Vow_12 a pl:Vow ; pl:vowNumber 12 ;
    rdfs:label "Boundless light"@en , "光明無量願"@zh-Hant , "광명무량원"@ko ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "The light of the buddha extends without limit — basis of the name 無量光."@en .

pl:Vow_13 a pl:Vow ; pl:vowNumber 13 ;
    rdfs:label "Boundless lifespan"@en , "壽命無量願"@zh-Hant , "수명무량원"@ko ;
    pl:appearsIn pl:T0360 ;
