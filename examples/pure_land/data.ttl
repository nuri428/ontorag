# STRUCTURES (in Sukhāvatī)
# ═════════════════════════════════════════════════════════════════════════════

pl:JeweledTower_Canonical a pl:JeweledTower ;
    rdfs:label "Seven-storied jeweled tower"@en , "七層寶樓閣"@zh-Hant , "칠층보배누각"@ko ;
    pl:storyCount 7 ;
    pl:locatedIn pl:Sukhavati ;
    pl:appearsIn pl:T0360 , pl:T0366 ;
    rdfs:comment "The canonical seven-storied jeweled tower of Sukhāvatī. T0360 specifies seven (七)."@en .

pl:LotusPond_Canonical a pl:LotusPond ;
    rdfs:label "Seven-jewel lotus pond"@en , "七寶池"@zh-Hant , "칠보지"@ko ;
    pl:locatedIn pl:Sukhavati ;
    pl:hasColor pl:BlueLotus , pl:YellowLotus , pl:RedLotus , pl:WhiteLotus ;
    pl:appearsIn pl:T0366 ;
    rdfs:comment "Filled with the water of eight virtues (八功德水); contains lotuses of four colours."@en .

pl:JeweledTree_Canonical a pl:JeweledTree ;
    rdfs:label "Jeweled tree"@en , "寶樹"@zh-Hant , "보배나무"@ko ;
    pl:locatedIn pl:Sukhavati ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "Tree composed of seven precious materials; its rustling proclaims the Dharma."@en .

