pl:Manjushri a pl:Bodhisattva ;
    rdfs:label "Mañjuśrī"@en , "文殊師利菩薩"@zh-Hant , "문수보살"@ko ;
    pl:sanskritName "Mañjuśrī" ;
    pl:residesIn pl:SahaWorld ;
    pl:appearsIn pl:T0366 ;
    rdfs:comment "Listed in T0366 as one of the great bodhisattvas in Śākyamuni's assembly."@en .

pl:Maitreya a pl:Bodhisattva ;
    rdfs:label "Maitreya"@en , "彌勒菩薩"@zh-Hant , "미륵보살"@ko ;
    skos:altLabel "Ajita"@en , "阿逸多"@zh-Hant , "아일다"@ko ;
    pl:sanskritName "Maitreya" ;
    pl:residesIn pl:SahaWorld ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "Future Buddha. Interlocutor of the latter half of T0360 (addressed as Ajita)."@en .

pl:Samantabhadra a pl:Bodhisattva ;
    rdfs:label "Samantabhadra"@en , "普賢菩薩"@zh-Hant , "보현보살"@ko ;
    pl:sanskritName "Samantabhadra" ;
    pl:appearsIn pl:T0360 .

pl:Gandhahastin a pl:Bodhisattva ;
    rdfs:label "Gandhahastin"@en , "香象菩薩"@zh-Hant , "향상보살"@ko ;
