# ═════════════════════════════════════════════════════════════════════════════
# REALMS
# ═════════════════════════════════════════════════════════════════════════════

pl:Sukhavati a pl:SacredRealm ;
    rdfs:label "Sukhāvatī"@en , "極樂世界"@zh-Hant , "극락세계"@ko ;
    pl:sanskritName "Sukhāvatī" ;
    pl:appearsIn pl:T0360 , pl:T0366 , pl:T0365 ;
    rdfs:comment "The Western Pure Land of Buddha Amitābha."@en .

pl:SahaWorld a pl:SahaWorld ;
    rdfs:label "Sahā world"@en , "娑婆世界"@zh-Hant , "사바세계"@ko ;
    pl:sanskritName "Sahā" ;
    pl:appearsIn pl:T0360 .

# ═════════════════════════════════════════════════════════════════════════════
# BUDDHAS
# ═════════════════════════════════════════════════════════════════════════════

pl:Amitabha a pl:Buddha ;
    rdfs:label "Amitābha"@en , "阿彌陀佛"@zh-Hant , "아미타불"@ko ;
    skos:altLabel "Amitāyus"@en , "無量壽佛"@zh-Hant , "무량수불"@ko ;
    pl:sanskritName "Amitābha" ;
    pl:residesIn pl:Sukhavati ;
    pl:appearsIn pl:T0360 , pl:T0366 , pl:T0365 ;
    rdfs:comment "Originally the bhikṣu Dharmākara (法藏比丘) who, fulfilling 48 vows, became the Buddha of Sukhāvatī."@en .

pl:Sakyamuni a pl:Buddha ;
    rdfs:label "Śākyamuni"@en , "釋迦牟尼佛"@zh-Hant , "석가모니불"@ko ;
    pl:sanskritName "Śākyamuni" ;
    pl:residesIn pl:SahaWorld ;
    pl:appearsIn pl:T0360 , pl:T0366 , pl:T0365 ;
    rdfs:comment "The historical Buddha who teaches the Pure Land sūtras in the Sahā world."@en .

pl:Akshobhya a pl:Buddha ;
    rdfs:label "Akṣobhya"@en , "阿閦佛"@zh-Hant , "아촉불"@ko ;
    pl:sanskritName "Akṣobhya" ;
    pl:appearsIn pl:T0366 ;
    rdfs:comment "Buddha of the East in T0366's six-direction praise of Amitābha."@en .

pl:Ratnasambhava a pl:Buddha ;
    rdfs:label "Ratnaketu"@en , "寶相佛"@zh-Hant , "보상불"@ko ;
    pl:sanskritName "Ratnaketu" ;
    pl:appearsIn pl:T0366 .

pl:Amoghasiddhi a pl:Buddha ;
    rdfs:label "Bhīṣmagarjitaghoṣasvara"@en , "難沮佛"@zh-Hant , "난저불"@ko ;
    pl:sanskritName "Bhīṣmagarjitaghoṣasvara" ;
    pl:appearsIn pl:T0366 .

pl:Dharmakara a pl:Bodhisattva ;
    rdfs:label "Dharmākara"@en , "法藏比丘"@zh-Hant , "법장비구"@ko ;
    pl:sanskritName "Dharmākara" ;
    pl:appearsIn pl:T0360 ;
    rdfs:comment "The bodhisattva who made the 48 vows and became Amitābha. Modelled as Bodhisattva to capture the pre-buddhahood state."@en ;
    owl:sameAs pl:Amitabha ;  # same individual at different stage; sameAs is doctrinally debatable but useful for goldset
    rdfs:seeAlso pl:Amitabha .

