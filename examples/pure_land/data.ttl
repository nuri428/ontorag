    pl:residesIn pl:Sukhavati ;
    pl:assists pl:Amitabha ;
    pl:appearsIn pl:T0360 , pl:T0365 ;
    rdfs:comment "Left attendant of Amitābha (西方三聖 left)."@en .

pl:Mahasthamaprapta a pl:Bodhisattva ;
