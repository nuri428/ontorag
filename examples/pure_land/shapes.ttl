@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix pl:   <https://ontorag.dev/ns/pure_land#> .

pl:VowShape
    a sh:NodeShape ;
    sh:targetClass pl:Vow ;
    sh:property [
        sh:path pl:vowNumber ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 48 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "법장보살의 본원은 1-48번 중 하나의 정수." ;
    ] .

pl:ContemplationShape
    a sh:NodeShape ;
    sh:targetClass pl:Contemplation ;
    sh:property [
        sh:path pl:contemplationOrder ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 16 ;
        sh:maxCount 1 ;
        sh:message "관무량수경의 16관 중 하나의 순서 (1-16)." ;
    ] .

pl:BodhisattvaShape
    a sh:NodeShape ;
    sh:targetClass pl:Bodhisattva ;
    sh:property [
        sh:path pl:assists ;
        sh:nodeKind sh:IRI ;
        sh:message "보살이 보좌하는 부처는 IRI여야 한다." ;
    ] .
