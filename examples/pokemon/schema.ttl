@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix pk:   <http://example.org/pokemon#> .

# ── Ontology declaration ──────────────────────────────────────────────────────

<http://example.org/pokemon>
    a owl:Ontology ;
    rdfs:label "Pokemon Ontology — ontorag demo" ;
    rdfs:comment "포켓몬 도메인 온톨로지 (1세대 중심). ontorag 프레임워크 시연용." .

# ── Classes ───────────────────────────────────────────────────────────────────

pk:Pokemon
    a owl:Class ;
    rdfs:label "Pokemon" ;
    rdfs:comment "포켓몬 개체. 하나 이상의 타입을 가지며 기술을 배울 수 있다." .

pk:LegendaryPokemon
    a owl:Class ;
    rdfs:subClassOf pk:Pokemon ;
    rdfs:label "Legendary Pokemon" ;
    rdfs:comment "전설의 포켓몬. 일반적으로 진화하지 않으며 스탯이 매우 높다." .

pk:Type
    a owl:Class ;
    rdfs:label "Type" ;
    rdfs:comment "포켓몬·기술의 속성 (불꽃, 물, 풀 등)." .

pk:Move
    a owl:Class ;
    rdfs:label "Move" ;
    rdfs:comment "포켓몬이 배울 수 있는 기술." .

pk:Trainer
    a owl:Class ;
    rdfs:label "Trainer" ;
    rdfs:comment "포켓몬 트레이너." .

pk:Region
    a owl:Class ;
    rdfs:label "Region" ;
    rdfs:comment "포켓몬 세계의 지역 (관동, 성도 등)." .

# ── Datatype properties — Pokemon ─────────────────────────────────────────────

pk:nationalDex
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "national dex number" ;
    rdfs:comment "전국도감 번호." .

pk:hp
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "HP" .

pk:attack
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "attack" .

pk:defense
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "defense" .

pk:spAttack
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "special attack" .

pk:spDefense
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "special defense" .

pk:speed
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "speed" .

pk:evolutionLevel
    a owl:DatatypeProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range xsd:integer ;
    rdfs:label "evolution level" ;
    rdfs:comment "이 포켓몬이 진화하는 데 필요한 레벨." .

# ── Datatype properties — Move ────────────────────────────────────────────────

pk:power
    a owl:DatatypeProperty ;
    rdfs:domain pk:Move ;
    rdfs:range xsd:integer ;
    rdfs:label "power" .

pk:accuracy
    a owl:DatatypeProperty ;
    rdfs:domain pk:Move ;
    rdfs:range xsd:integer ;
    rdfs:label "accuracy" .

pk:category
    a owl:DatatypeProperty ;
    rdfs:domain pk:Move ;
    rdfs:range xsd:string ;
    rdfs:label "category" ;
    rdfs:comment "물리(Physical), 특수(Special), 변화(Status)" .

# ── Datatype properties — Trainer / Region ────────────────────────────────────

pk:hometown
    a owl:DatatypeProperty ;
    rdfs:domain pk:Trainer ;
    rdfs:range xsd:string ;
    rdfs:label "hometown" .

# ── Object properties ─────────────────────────────────────────────────────────

pk:hasType
    a owl:ObjectProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range pk:Type ;
    rdfs:label "has type" ;
    rdfs:comment "포켓몬의 속성 (최대 2개)." .

pk:hasMove
    a owl:ObjectProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range pk:Move ;
    rdfs:label "has move" ;
    rdfs:comment "포켓몬이 배울 수 있는 기술." .

pk:moveType
    a owl:ObjectProperty ;
    rdfs:domain pk:Move ;
    rdfs:range pk:Type ;
    rdfs:label "move type" .

pk:evolvesFrom
    a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range pk:Pokemon ;
    rdfs:label "evolves from" ;
    rdfs:comment "직접 진화 전 단계. TransitiveProperty이므로 추론 시 전체 진화 체인을 추적함." .

pk:trainedBy
    a owl:ObjectProperty ;
    rdfs:domain pk:Pokemon ;
    rdfs:range pk:Trainer ;
    rdfs:label "trained by" .

pk:fromRegion
    a owl:ObjectProperty ;
    rdfs:domain pk:Trainer ;
    rdfs:range pk:Region ;
    rdfs:label "from region" .

pk:strongAgainst
    a owl:ObjectProperty ;
    rdfs:domain pk:Type ;
    rdfs:range pk:Type ;
    rdfs:label "strong against" ;
    rdfs:comment "이 속성의 기술이 상대 속성에 효과가 좋음 (×2)." .

pk:weakAgainst
    a owl:ObjectProperty ;
    rdfs:domain pk:Type ;
    rdfs:range pk:Type ;
    rdfs:label "weak against" ;
    rdfs:comment "이 속성의 기술이 상대 속성에 효과가 별로 (×0.5)." .
