# ── Graph Store ──────────────────────────────────────────────────────────────
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=ontorag
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai | ollama
ANTHROPIC_API_KEY=sk-ant-...    # required for Anthropic
# OPENAI_API_KEY=sk-...         # required for OpenAI
# OLLAMA_BASE_URL=http://localhost:11434  # required for Ollama
# LLM_MODEL=claude-sonnet-4-6   # optional: override default model

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
