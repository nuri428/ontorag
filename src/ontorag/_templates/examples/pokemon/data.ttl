    pk:spDefense "50"^^xsd:integer ;
    pk:speed "90"^^xsd:integer ;
    pk:hasType d:TypeElectric ;
    pk:hasMove d:MoveThunderbolt, d:MoveTackle, d:MoveThunder ;
    pk:evolvesFrom d:Pichu ;
    pk:trainedBy d:TrainerAsh .

d:Raichu
    a pk:Pokemon ;
    rdfs:label "라이츄" ;
