d:Blastoise
    a pk:Pokemon ;
    rdfs:label "거북왕" ;
    pk:nationalDex "9"^^xsd:integer ;
    pk:hp "79"^^xsd:integer ;
    pk:attack "83"^^xsd:integer ;
    pk:defense "100"^^xsd:integer ;
    pk:spAttack "85"^^xsd:integer ;
    pk:spDefense "105"^^xsd:integer ;
    pk:speed "78"^^xsd:integer ;
    pk:hasType d:TypeWater ;
    pk:hasMove d:MoveSurfing, d:MoveHydroCanon ;
    pk:evolvesFrom d:Wartortle ;
    pk:trainedBy d:TrainerMisty .

# ── Pokemon — 피카츄 (Electric) ───────────────────────────────────────────────

d:Pichu
    a pk:Pokemon ;
