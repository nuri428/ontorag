# ── Pokemon — 뮤츠 (Legendary, Psychic) ──────────────────────────────────────

d:Mewtwo
    a pk:LegendaryPokemon ;
    rdfs:label "뮤츠" ;
    pk:nationalDex "150"^^xsd:integer ;
    pk:hp "106"^^xsd:integer ;
    pk:attack "110"^^xsd:integer ;
    pk:defense "90"^^xsd:integer ;
    pk:spAttack "154"^^xsd:integer ;
    pk:spDefense "90"^^xsd:integer ;
    pk:speed "130"^^xsd:integer ;
    pk:hasType d:TypePsychic ;
    pk:hasMove d:MovePsychic, d:MoveFlamethrower, d:MoveThunderbolt .

# ── Pokemon — 피죤투 (Normal / Flying) ───────────────────────────────────────

d:Pidgeot
    a pk:Pokemon ;
    rdfs:label "피죤투" ;
    pk:nationalDex "18"^^xsd:integer ;
    pk:hp "83"^^xsd:integer ;
    pk:attack "80"^^xsd:integer ;
    pk:defense "75"^^xsd:integer ;
    pk:spAttack "70"^^xsd:integer ;
    pk:spDefense "70"^^xsd:integer ;
    pk:speed "101"^^xsd:integer ;
    pk:hasType d:TypeNormal, d:TypeFlying ;
