d:Snorlax
    a pk:Pokemon ;
    rdfs:label "잠만보" ;
    pk:nationalDex "143"^^xsd:integer ;
    pk:hp "160"^^xsd:integer ;
    pk:attack "110"^^xsd:integer ;
    pk:defense "65"^^xsd:integer ;
