    pk:nationalDex "172"^^xsd:integer ;
    pk:hp "20"^^xsd:integer ;
    pk:attack "40"^^xsd:integer ;
    pk:defense "15"^^xsd:integer ;
    pk:spAttack "35"^^xsd:integer ;
    pk:spDefense "35"^^xsd:integer ;
    pk:speed "60"^^xsd:integer ;
    pk:hasType d:TypeElectric ;
    pk:hasMove d:MoveTackle .

d:Pikachu
    a pk:Pokemon ;
    rdfs:label "피카츄" ;
    pk:nationalDex "25"^^xsd:integer ;
    pk:hp "35"^^xsd:integer ;
    pk:attack "55"^^xsd:integer ;
    pk:defense "40"^^xsd:integer ;
